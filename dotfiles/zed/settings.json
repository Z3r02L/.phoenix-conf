// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "format_on_save": "off",
  "base_keymap": "VSCode",
  "vim_mode": false,
  "helix_mode": false,
  "tab_size": 2,
  "autosave": "on_focus_change",
  "toolbar": {
    "breadcrumbs": true
  },
  "language_models": {
    "openai_compatible": {
      "z.ai": {
        "api_url": "https://api.z.ai/api/coding/paas/v4/",
        "available_models": [
          {
            "name": "glm-4.6",
            "display_name": null,
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": true,
              "parallel_tool_calls": false,
              "prompt_cache_key": false
            }
          }
        ]
      }
    }
  },
  "agent": {
    "profiles": {
      "pnpm-+-vue-js": {
        "name": "PNPM + VueJS",
        "tools": {},
        "enable_all_context_servers": false,
        "context_servers": {}
      }
    },
    "play_sound_when_agent_done": true,
    "default_profile": "write",
    "default_model": {
      "provider": "google",
      "model": "gemini-3-flash-preview"
    }
  },
  "agent_servers": {
    "Qwen Code": {
      "type": "custom",
      "command": "qwen",
      "args": [
        "--experimental-acp"
      ],
      "env": {}
    }
  },
  "context_servers": {
    "browsermcp": {
      "enabled": true,
      "command": "npx",
      "args": [
        "@browsermcp/mcp@latest"
      ],
      "env": {}
    },
    "chrome-devtools-mcp-zed": {
      "enabled": true,
      "settings": {
        "browser_url": null,
        "ws_endpoint": null,
        "ws_headers": null,
        "auto_connect": null,
        "channel": null,
        "headless": null,
        "isolated": null,
        "user_data_dir": null,
        "viewport": null,
        "executable_path": null,
        "chrome_arg": [],
        "proxy_server": null,
        "accept_insecure_certs": null,
        "category_emulation": null,
        "category_performance": null,
        "category_network": null,
        "log_file": null,
        "extra_args": []
      }
    },
    "browser-tools-context-server": {
      "enabled": true,
      "settings": {}
    },
    "mcp-server-vercel": {
      "enabled": true,
      "settings": {
        "url": "https://your-mcp-server.vercel.app/api/mcp"
      }
    },
    "mcp-server-supabase": {
      "enabled": false,
      "settings": {
        "supabase_access_token": "YOUR_TOKEN",
        "read_only": false
      }
    },
    "mcp-server-context7": {
      "enabled": true,
      "settings": {
        "default_minimum_tokens": "10000"
      }
    },
    // "context7": {
    //   "command": "npx",
    //   "args": [
    //     "-y",
    //     "@upstash/context7-mcp"
    //   ],
    //   "env": {
    //     "DEFAULT_MINIMUM_TOKENS": "6000"
    //   },
    //   "alwaysAllow": [
    //     "resolve-library-id",
    //     "get-library-docs"
    //   ]
    // },
    // Secret-backed context servers such as Figma, Linear, or custom
    // OpenAI/Milvus integrations are intentionally omitted here so the file
    // is safe to keep in dotfiles and symlink for live editing.
    "shadcn": {
      "command": "npx",
      "args": ["shadcn@latest", "mcp"]
    },
    "nx-mcp": {
      "command": "npx",
      "args": ["nx-mcp@latest"]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    }
  },
  "icon_theme": "VSCode Icons for Zed (Dark)",
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "theme": "Ayu Dark",
  "languages": {
    "Go": {
      "language_servers": ["gopls"]
    },
    "TypeScript": {
      "language_servers": ["typescript-language-server"]
    },
    "Nix": {
      "language_servers": ["nixd", "!nil"],
      "formatter": {
        "external": {
          "command": "alejandra", // or "nixfmt"
          "arguments": ["--quiet", "--"]
        }
      }
    }
  },
  "lsp": {
    "tailwindcss-language-server": {
      "settings": {
        "classFunctions": ["cva", "cx"],
        "experimental": {
          "classRegex": ["[cls|className]\\s\\:\\=\\s\"([^\"]*)"]
        }
      }
    },
    "vue": {
      "initialization_options": {
        "typescript": {
          "tsdk": ".yarn/sdks/typescript/lib"
        }
      }
    },
    "nixd": {
      "settings": {
        "diagnostic": {
          "suppress": ["sema-extra-with"]
        }
      }
    }
  }
}
