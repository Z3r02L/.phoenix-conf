	"eslint.codeAction.showDocumentation": {
		"enable": true
	},
	"eslint.quiet": true,
	"eslint.validate": [
		"javascript",
		"typescript",
		"javascriptreact",
		"typescriptreact",
		"vue",
		"html",
		"markdown",
		"json",
		"jsonc",
		"json5"
	],
