{
  "cheatsheetData": [
    {
      "title": "Applications",
      "binds": [
        {
          "keys": "Super + Return",
          "desc": "Open a Terminal: kitty"
        },
        {
          "keys": "Super + D",
          "desc": "Run an Application: fuzzel"
        },
        {
          "keys": "Super + Alt + L",
          "desc": "Lock the Screen: swaylock"
        },
        {
          "keys": "Super + Alt + R",
          "desc": "Restart Shell: Noctalia"
        },
        {
          "keys": "Vol Up",
          "desc": "Run: wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.1+"
        },
        {
          "keys": "Vol Down",
          "desc": "Run: wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.1-"
        },
        {
          "keys": "Mute",
          "desc": "Run: wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
        },
        {
          "keys": "Mic Mute",
          "desc": "Run: wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle"
        },
        {
          "keys": "Bright Up",
          "desc": "Run: brightnessctl"
        },
        {
          "keys": "Bright Down",
          "desc": "Run: brightnessctl"
        }
      ]
    },
